<?xml version="1.0" encoding="utf-8"?>
<!--
    Pathrift Adaptive Icon — Foreground Layer
    Design: Geometric bold "P" in neon blue (#00C8FF) with purple path-dash accent
    Glow layers: semi-transparent circles simulating neon bloom
    Safe zone: 72dp center square (18dp inset on all sides within 108dp viewport)
    Viewport: 108x108dp
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- === GLOW LAYERS (outermost to innermost) === -->

    <!-- Outer glow bloom — neon blue, very faint -->
    <path
        android:fillColor="#00C8FF"
        android:fillAlpha="0.06"
        android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0"/>

    <!-- Mid glow — slightly stronger -->
    <path
        android:fillColor="#00C8FF"
        android:fillAlpha="0.10"
        android:pathData="M54,54 m-22,0 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0"/>

    <!-- Inner glow halo — purple tint -->
    <path
        android:fillColor="#8B4FFF"
        android:fillAlpha="0.08"
        android:pathData="M54,54 m-16,0 a16,16 0 1,0 32,0 a16,16 0 1,0 -32,0"/>

    <!-- === STYLIZED "P" LETTERFORM ===
         Geometric construction:
         - Vertical stem: x=37 to x=44, y=26 to y=82  (7dp wide, 56dp tall)
         - Bowl top-left arc origin at (44, 26)
         - Bowl spans from y=26 to y=52, right edge at x=67
         - Bowl is a rounded rectangle / D-shape on the right side of stem

         Coordinates (all within 72dp safe zone, centered at 54,54):
         Safe zone: x[18..90], y[18..90] — we use x[37..70], y[26..82]
    -->

    <!-- Vertical stem of P -->
    <path
        android:fillColor="#00C8FF"
        android:pathData="
            M37,26
            L44,26
            L44,82
            L37,82
            Z"/>

    <!-- Bowl of P — upper right rounded shape
         Top bar: x=44 to x=63, y=26 to y=31
         Right curve: from (63,31) arc to (63,51), radius ~10
         Bottom bar: x=44 to x=63, y=47 to y=52
         Left side already closed by stem
    -->
    <path
        android:fillColor="#00C8FF"
        android:pathData="
            M44,26
            L61,26
            Q70,26 70,35
            L70,43
            Q70,52 61,52
            L44,52
            L44,47
            L60,47
            Q65,47 65,43
            L65,35
            Q65,31 60,31
            L44,31
            Z"/>

    <!-- === PATH / TRAIL ACCENT — purple dashed line below P ===
         Represents a "path" or trail — the tower-defense route theme
         Positioned in lower safe zone: y=68 to y=72, x=37 to x=71
    -->

    <!-- Dash 1 -->
    <path
        android:fillColor="#8B4FFF"
        android:pathData="M37,68 L47,68 L47,71 L37,71 Z"/>

    <!-- Dash 2 -->
    <path
        android:fillColor="#8B4FFF"
        android:pathData="M50,68 L60,68 L60,71 L50,71 Z"/>

    <!-- Dash 3 -->
    <path
        android:fillColor="#8B4FFF"
        android:pathData="M63,68 L71,68 L71,71 L63,71 Z"/>

    <!-- Arrow head pointing right on the path trail -->
    <path
        android:fillColor="#8B4FFF"
        android:pathData="
            M71,65.5
            L76,69.5
            L71,73.5
            Z"/>

    <!-- === STEM INNER HIGHLIGHT — thin bright line on left edge of stem ===
         Simulates neon tube lighting
    -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.35"
        android:pathData="M37,26 L39,26 L39,82 L37,82 Z"/>

    <!-- Bowl top highlight — thin bright line along top of bowl -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.25"
        android:pathData="M44,26 L65,26 Q70,26 70,31 L68,31 Q68,28 64,28 L44,28 Z"/>

    <!-- === SUBTLE ORANGE ACCENT DOT — tower node indicator ===
         Small dot at bowl junction — #FF6B00 orange
    -->
    <path
        android:fillColor="#FF6B00"
        android:fillAlpha="0.85"
        android:pathData="M44,49 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0"/>

</vector>
