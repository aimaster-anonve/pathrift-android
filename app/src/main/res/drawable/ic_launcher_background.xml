<?xml version="1.0" encoding="utf-8"?>
<!--
    Pathrift Adaptive Icon — Background Layer
    Base: #0A0A0F (deep space black)
    Subtle grid lines at ~3% white opacity to evoke a tactical/tower-defense map grid
    Viewport: 108x108dp
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base fill: deep space black -->
    <path
        android:fillColor="#0A0A0F"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"/>

    <!-- Subtle radial dark gradient overlay — center slightly lighter -->
    <path
        android:fillColor="#14141A"
        android:fillAlpha="0.45"
        android:pathData="M54,54 m-38,0 a38,38 0 1,0 76,0 a38,38 0 1,0 -76,0"/>

    <!-- Grid lines — horizontal, ~3% white opacity -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.03"
        android:strokeWidth="0.5"
        android:fillColor="#00000000"
        android:pathData="
            M0,18 L108,18
            M0,36 L108,36
            M0,54 L108,54
            M0,72 L108,72
            M0,90 L108,90"/>

    <!-- Grid lines — vertical, ~3% white opacity -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.03"
        android:strokeWidth="0.5"
        android:fillColor="#00000000"
        android:pathData="
            M18,0 L18,108
            M36,0 L36,108
            M54,0 L54,108
            M72,0 L72,108
            M90,0 L90,108"/>

    <!-- Very faint diagonal accent lines — top-left to bottom-right -->
    <path
        android:strokeColor="#00C8FF"
        android:strokeAlpha="0.025"
        android:strokeWidth="0.4"
        android:fillColor="#00000000"
        android:pathData="
            M-10,28 L28,-10
            M-10,64 L64,-10
            M-10,100 L100,-10
            M28,118 L118,28
            M64,118 L118,64
            M100,118 L118,100"/>

</vector>
